# Database - Using SQLite for deployment (no external DB needed)
# DATABASE_URL=sqlite:///./test.db  # Default SQLite database

# FastAPI
APP_NAME=Diabetic Ulcer AI System
APP_VERSION=1.0.0
LOG_LEVEL=INFO

# Security
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ML Model Paths
CNN_MODEL_PATH=backend/models/best_dfu_model.pth
SEGMENTATION_MODEL_PATH=backend/models/segmentation_model.pth
MULTIMODAL_MODEL_PATH=backend/models/multimodal_model.pth

# CORS - Production URLs
ALLOWED_ORIGINS=https://medvision-ai-frontend.onrender.com,http://localhost:3000,http://localhost:8000,http://localhost:5173

# Explainability
SHAP_BACKGROUND_SAMPLES=100
LIME_SAMPLES=1000

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=diabetic-ulcer-detection

# Email Configuration (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=bharat.833498@gmail.com
SMTP_PASSWORD=ndqeneegctvnfggp
SMTP_FROM_EMAIL=noreply@diabeticulcer.com
SMTP_FROM_NAME=Diabetic Ulcer AI System

# Frontend URL - Production
FRONTEND_URL=https://medvision-ai-frontend.onrender.com

# Environment
ENVIRONMENT=production
